# =============================================================================
# LoyaltyApp — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# App identity — must match manifest.xml <name> and <secret>
APP_NAME=LoyaltyApp
APP_SECRET=localDevSecretDoNotUseInProduction

# Public URL of this app (ngrok URL in dev, production domain in prod)
# Must match the URLs in manifest.xml (no trailing slash)
APP_URL=https://REPLACE_WITH_NGROK_URL

# Database (Postgres via Supabase)
DATABASE_URL=postgresql://postgres:password@localhost:5432/loyalty

# Encryption key for Shopware credentials (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Postmark API token for transactional emails
POSTMARK_API_TOKEN=

# Shared secret for cron endpoints
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
